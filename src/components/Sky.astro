---
import { hashSeed, seededRandom } from "@utils/random";

const { star_intensity = 100, nebula = true, meteor_count = 5 } = Astro.props;

const bgStars = Array.from({ length: star_intensity }, (_, i) => {
    const seed = hashSeed(`bg-${i}`);
    const x = seededRandom(seed) * 100;
    const y = seededRandom(seed + 1) * 100;
    const size = 0.5 + seededRandom(seed + 2) * 2;
    const opacity = 0.15 + seededRandom(seed + 3) * 0.45;
    return { x, y, size, opacity };
});

const bgMeteors = Array.from({ length: meteor_count }, (_, i) => {
    const seed = hashSeed(`meteor-${i}`);
    const x = 50 + seededRandom(seed) * 100;
    const y = -50 + seededRandom(seed + 1) * 100;
    const height = 40 + seededRandom(seed + 2) * 80;
    const delay = seededRandom(seed + 3) * 20;
    const duration = 4 + seededRandom(seed + 4) * 6;
    const brightness = 0.3 + seededRandom(seed + 5) * 0.7;
    return { x, y, height, delay, duration, brightness };
});
---

{
    bgStars.map((b) => (
        <div
            class="pointer-events-none absolute rounded-full bg-white"
            style={`left:${b.x}%; top:${b.y}%; width:${b.size}px; height:${b.size}px; opacity:${b.opacity};`}
        />
    ))
}

{
    bgMeteors.map((m) => (
        <div
            class="meteor pointer-events-none"
            style={`left:${m.x}%; top:${m.y}%; height:${m.height}px; animation-delay:${m.delay}s; animation-duration:${m.duration}s; background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, ${m.brightness}));`}
        />
    ))
}

{
    nebula && (
        <>
            <div
                class="nebula"
                style="left:-5%;top:-10%;width:75%;height:65%;background:radial-gradient(ellipse,rgba(220,38,38,0.08) 0%,transparent 70%);"
            ></div>
            <div
                class="nebula"
                style="left:40%;top:-5%;width:85%;height:70%;background:radial-gradient(ellipse,rgba(16,185,129,0.07) 0%,transparent 70%);"
            ></div>
            <div
                class="nebula"
                style="left:-10%;top:45%;width:80%;height:75%;background:radial-gradient(ellipse,rgba(245,158,11,0.06) 0%,transparent 70%);"
            ></div>
            <div
                class="nebula"
                style="left:45%;top:50%;width:90%;height:80%;background:radial-gradient(ellipse,rgba(6,182,212,0.07) 0%,transparent 70%);"
            ></div>
            <div
                class="nebula"
                style="left:15%;top:15%;width:100%;height:85%;background:radial-gradient(ellipse,rgba(139,92,246,0.05) 0%,transparent 70%);"
            ></div>
        </>
    )
}

<script>
    document.querySelectorAll('.meteor').forEach(m => {
        m.addEventListener('animationiteration', (e) => {
            const el = e.target as HTMLElement;
            el.style.left = Math.floor(Math.random() * 100) + '%';
            el.style.top = Math.floor(-50 + Math.random() * 100) + '%';
        });
    });
</script>

<style is:global>
    .nebula {
        @apply pointer-events-none absolute rounded-full filter;
        transform: translate(-50%, -50%);
    }

    .meteor {
        position: absolute;
        width: 2px;
        animation: meteor linear infinite;
        opacity: 0;
    }

    @keyframes meteor {
        0% { transform: rotate(60deg) translateY(0); opacity: 1; }
        20% { transform: rotate(60deg) translateY(100vmax); opacity: 0; }
        100% { opacity: 0; }
    }
</style>