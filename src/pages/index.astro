---
import { createClient } from "@libsql/client";
// prettier-ignore
import { getRandomStar, setChromaticity, setSize, setLuminosity } from "@utils/star";
import { setPosition } from "@utils/positioning";
import { hashSeed, seededRandom } from "@utils/random";

import Layout from "../layouts/Layout.astro";

import Star from "../components/Star.astro";
import BackgroundStars from "../components/BackgroundStars.astro";
import Nebula from "../components/Nebula.astro";

import starCatalog from "../data/star-catalog.json";

const turso = createClient({
	url: import.meta.env.TURSO_DATABASE_URL,
	authToken: import.meta.env.TURSO_AUTH_TOKEN,
});

const entries = await turso.execute("SELECT * FROM stars");
const starByHR = Object.fromEntries(starCatalog.map((s) => [s.HR, s]));

const stars = entries.rows
	.map((row) => {
		const star = starByHR[row.star_hr as string];
		if (!star) return null;

		const vmag = parseFloat(star.Vmag) || 3;
		const color = setChromaticity(star["Sp Type"]);
		const size = setSize(vmag);
		const glow = setLuminosity(vmag);
		const beamLen = size * 5;
		const beamW = Math.max(1.5, size * 0.18);

		const seed = hashSeed(
			`${row.star_hr}-${row.name}-${row.birth_year}-${row.death_year}`,
		);
		const pos = setPosition(seed);
		const pulseDelay = (seededRandom(seed + 999) * 3).toFixed(2);

		const starLabel = star.Name ? star.Name : `HR ${row.star_hr}`;

		return {
			color,
			size,
			glow,
			beamLen,
			beamW,
			x: 35 + pos.x * 0.3,
			y: 35 + pos.y * 0.3,
			pulseDelay,
			name: row.name as string,
			birthYear: row.birth_year as string,
			deathYear: row.death_year as string,
			starLabel,
		};
	})
	.filter((s): s is NonNullable<typeof s> => s !== null);
---

<Layout>
	<div id="viewport" class="bg-sky-dark fixed inset-0 z-10 overflow-hidden">
		<div id="canvas" class="absolute h-[500vh] w-[500vw] origin-center">
			<BackgroundStars />
			<Nebula />
			{stars.map((s) => <Star {...s} />)}
		</div>
	</div>

	<div class="pointer-events-none fixed inset-0 z-100">
		<div class="flex justify-center p-10" 2>
			<a
				href="/"
				class="pointer-events-auto cursor-pointer text-lg tracking-[5px] uppercase"
			>
				Still, We Shine
			</a>
		</div>
	</div>
	<script>
		import Panzoom from "@panzoom/panzoom";

		const canvas = document.getElementById("canvas")!;
		const viewport = document.getElementById("viewport")!;

		const panzoom = Panzoom(canvas, {
			maxScale: 10,
			minScale: 0.2,
			contain: "outside",
			canvas: true,
			cursor: "arrow",
			startScale: 1,
			startX: -(canvas.offsetWidth - window.innerWidth) / 2,
			startY: -(canvas.offsetHeight - window.innerHeight) / 2,
		});

		viewport.addEventListener("wheel", panzoom.zoomWithWheel, {
			passive: false,
		});
	</script>
</Layout>
